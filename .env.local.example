# Telegram-бот для заявок с формы бронирования
# Скопируйте этот файл в .env.local и заполните значения

# 1. Создайте бота через @BotFather в Telegram, командой /newbot
# 2. Скопируйте сюда токен, который выдаст BotFather
TELEGRAM_BOT_TOKEN=

# 3. Напишите своему боту любое сообщение в Telegram
# 4. Откройте https://api.telegram.org/bot<ТОКЕН>/getUpdates
#    и найдите "chat":{"id": ...} — это ваш chat_id
# (можно также использовать chat_id группы — добавьте бота в группу администратором)
TELEGRAM_CHAT_ID=
