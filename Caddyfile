# Caddy reverse proxy for vostok guesthouse
# Email below — для писем от Let's Encrypt о сроках сертификата

{
    email saretsdkfhs@gmail.com
}

gostevoydomvostok.ru, www.gostevoydomvostok.ru {
    encode gzip zstd
    reverse_proxy app:3000

    # Безопасность
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Логирование
    log {
        output file /data/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}
